DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 后台数据面板：请求头 x-admin-key 或 URL ?key= 与此值一致方可读统计
ADMIN_ANALYTICS_KEY=change_me_to_a_long_random_secret

# （可选）Vercel 上稳定保存占卦会话：在 https://console.upstash.com 创建 Redis，复制 REST URL 与 Token
# 配置后全站会话走 Redis，多实例/冷启动仍可追问；不设则本地用文件、Vercel 仅用内存+/tmp（不可靠）
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxx

